# 複製為 .env 後修改
# --- OpenAI 相容端點（預設 LM Studio 本機伺服器）---
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
# 留空 = 自動用端點上第一個模型；建議載入視覺模型（如 qwen2.5-vl-7b）以讀取頁面截圖
LLM_MODEL=

# --- 檢索與多模態 ---
TOP_K=8
SEND_IMAGES=auto      # auto / on / off
MAX_IMAGES=3
RENDER_DPI=110
MAX_TOKENS=2048
TEMPERATURE=0.2
